{
  "name": "stackedit",
  "version": "5.15.4",
  "description": "Free, open-source, full-featured Markdown editor",
  "author": "Benoit Schweblin",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/benweet/stackedit/issues"
  },
  "main": "index.js",
  "scripts": {
    "start": "node build/dev-server.js",
    "build": "node build/build.js && npm run build-style && npm run check-bundle-size",
    "build-style": "webpack --config build/webpack.style.conf.js",
    "check-bundle-size": "node build/check-bundle-size.js",
    "lint": "npm run lint:js && npm run lint:styles",
    "lint:js": "eslint \"src/**/*.{js,vue}\" \"server/**/*.js\"",
    "lint:styles": "stylelint \"src/**/*.{scss,vue}\"",
    "unit": "jest --config test/unit/jest.conf.js --runInBand",
    "unit-with-coverage": "jest --config test/unit/jest.conf.js --runInBand --coverage",
    "test": "npm run lint && npm run unit",
    "preversion": "npm run test",
    "postversion": "git push origin master --tags && npm publish",
    "patch": "npm version patch -m \"Tag v%s\"",
    "minor": "npm version minor -m \"Tag v%s\"",
    "major": "npm version major -m \"Tag v%s\"",
    "chart": "mkdir -p dist && rm -rf dist/stackedit && cp -r chart dist/stackedit && sed -i.bak -e s/STACKEDIT_VERSION/$npm_package_version/g dist/stackedit/*.yaml && rm dist/stackedit/*.yaml.bak"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1087.0",
    "@babel/runtime": "^7.29.7",
    "abcjs": "^6.6.4",
    "bezier-easing": "^1.1.0",
    "body-parser": "^1.20.6",
    "clipboard": "^1.7.1",
    "compression": "^1.8.1",
    "core-js": "^3.49.0",
    "diff-match-patch": "^1.0.0",
    "dompurify": "^3.4.12",
    "express": "^4.22.2",
    "file-saver": "^1.3.8",
    "google-auth-library": "^10.9.0",
    "handlebars": "^4.7.9",
    "ipaddr.js": "^1.9.1",
    "js-yaml": "^5.2.1",
    "katex": "^0.17.0",
    "markdown-it": "^14.3.0",
    "markdown-it-abbr": "^2.0.0",
    "markdown-it-deflist": "^3.0.1",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-imsize": "^2.0.1",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-pandoc-renderer": "1.2.0",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
    "mermaid": "^11.16.0",
    "mousetrap": "^1.6.1",
    "normalize.css": "^8.0.1",
    "parse5": "^7.3.0",
    "prismjs": "^1.30.0",
    "regenerator-runtime": "^0.14.1",
    "serve-static": "^1.16.3",
    "tmp": "^0.2.7",
    "turndown": "^7.2.4",
    "vue": "^3.5.39",
    "vuex": "^4.1.0",
    "workbox-window": "^7.4.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/eslint-parser": "^7.29.7",
    "@babel/plugin-transform-runtime": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@eslint/js": "^9.39.5",
    "@vue/compiler-sfc": "^3.5.39",
    "@vue/test-utils": "^2.4.11",
    "@vue/vue3-jest": "^29.2.6",
    "ajv": "^8.20.0",
    "autoprefixer": "^10.5.3",
    "babel-jest": "^29.7.0",
    "babel-loader": "^8.4.1",
    "babel-plugin-transform-import-meta": "^3.0.0",
    "chalk": "^1.1.3",
    "connect-history-api-fallback": "^2.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "eslint": "^9.39.5",
    "eslint-import-resolver-webpack": "^0.13.11",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vue": "^10.9.2",
    "eventsource-polyfill": "^0.9.6",
    "friendly-errors-webpack-plugin": "^1.7.0",
    "globals": "^17.7.0",
    "html-webpack-plugin": "^5.6.7",
    "http-proxy-middleware": "^4.2.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "mini-css-extract-plugin": "^2.10.2",
    "opn": "^4.0.2",
    "ora": "^1.2.0",
    "postcss": "^8.5.19",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "replace-in-file": "^4.1.0",
    "sass": "^1.101.0",
    "sass-loader": "^17.0.0",
    "semver": "^5.5.0",
    "shelljs": "^0.8.1",
    "string-replace-loader": "^2.1.1",
    "stylelint": "^17.14.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "terser-webpack-plugin": "^5.6.1",
    "vue-eslint-parser": "^10.4.1",
    "vue-loader": "^17.4.2",
    "vue-style-loader": "^4.1.3",
    "webpack": "^5.108.4",
    "webpack-bundle-analyzer": "^5.3.1",
    "webpack-cli": "^7.2.1",
    "webpack-dev-middleware": "^8.0.3",
    "webpack-hot-middleware": "^2.26.1",
    "webpack-merge": "^6.0.1",
    "workbox-webpack-plugin": "^7.4.1"
  },
  "engines": {
    "node": ">= 22.0.0",
    "npm": ">= 10.0.0"
  },
  "overrides": {
    "mkdirp": "^0.5.6"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie <= 10"
  ]
}
