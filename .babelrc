{
  "presets": [
    ["@babel/preset-env", { "modules": false }]
  ],
  "plugins": ["@babel/plugin-transform-runtime"],
  "comments": false,
  "env": {
    "test": {
      "presets": [
        ["@babel/preset-env", {
          "modules": "commonjs",
          "targets": {
            "node": "current"
          }
        }]
      ],
      "plugins": [
        "@babel/plugin-transform-runtime",
        "transform-import-meta"
      ]
    }
  }
}
